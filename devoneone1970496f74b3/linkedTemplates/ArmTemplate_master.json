{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "devoneone1970496f74b3"
		},
		"DataLakeStorageGen2Sink_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'DataLakeStorageGen2Sink'"
		},
		"DataLakeStorageGen2Sink_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://devac1970496f74b3.dfs.core.windows.net/"
		},
		"breweries_api_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://api.openbrewerydb.org/v1/breweries"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "devoneone1970496f74b3_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"DataLakeStorageGen2Sink_accountKey": {
						"value": "[parameters('DataLakeStorageGen2Sink_accountKey')]"
					},
					"DataLakeStorageGen2Sink_properties_typeProperties_url": {
						"value": "[parameters('DataLakeStorageGen2Sink_properties_typeProperties_url')]"
					},
					"breweries_api_properties_typeProperties_url": {
						"value": "[parameters('breweries_api_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}