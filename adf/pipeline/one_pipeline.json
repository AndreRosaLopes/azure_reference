{
	"name": "one_pipeline",
	"properties": {
		"activities": [
			{
				"name": "beweries",
				"type": "DatabricksJob",
				"dependsOn": [
					{
						"activity": "breweries_api",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.00:10:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"jobId": "439877275774515"
				},
				"linkedServiceName": {
					"referenceName": "Serverless",
					"type": "LinkedServiceReference"
				}
			},
			{
				"name": "breweries_api",
				"type": "Until",
				"dependsOn": [],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@not(empty(activity('breweries').output))",
						"type": "Expression"
					},
					"activities": [
						{
							"name": "breweries",
							"type": "Copy",
							"dependsOn": [],
							"policy": {
								"timeout": "0.00:10:00",
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "RestSource",
									"httpRequestTimeout": "00:01:40",
									"requestInterval": "00.00:00:00.010",
									"requestMethod": "GET"
								},
								"sink": {
									"type": "JsonSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings",
										"copyBehavior": "FlattenHierarchy"
									},
									"formatSettings": {
										"type": "JsonWriteSettings"
									}
								},
								"enableStaging": false
							},
							"inputs": [
								{
									"referenceName": "source_rest_breweries",
									"type": "DatasetReference",
									"parameters": {
										"p_api_breweries_page": {
											"value": "@variables('api_breweries_page')",
											"type": "Expression"
										}
									}
								}
							],
							"outputs": [
								{
									"referenceName": "sink_json_adls2",
									"type": "DatasetReference",
									"parameters": {
										"p_container": "one",
										"p_folder": {
											"value": "api/breweries/year=@{\n    formatDateTime(convertFromUtc(utcNow(),'E. South America Standard Time'),'yyyy')\n}/month=@{\n    formatDateTime(convertFromUtc(utcNow(),'E. South America Standard Time'),'MM')\n}/day=@{\n    formatDateTime(convertFromUtc(utcNow(),'E. South America Standard Time'),'dd')\n}\n",
											"type": "Expression"
										},
										"p_file": "beweries.json"
									}
								}
							]
						},
						{
							"name": "set next page",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "breweries",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "api_breweries_nextPage",
								"value": {
									"value": "@add(variables('api_breweries_page'),1)",
									"type": "Expression"
								}
							}
						},
						{
							"name": "set page",
							"type": "SetVariable",
							"dependsOn": [
								{
									"activity": "set next page",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"variableName": "api_breweries_page",
								"value": {
									"value": "@variables('api_breweries_nextPage')",
									"type": "Expression"
								}
							}
						}
					],
					"timeout": "0.12:00:00"
				}
			}
		],
		"variables": {
			"api_breweries_page": {
				"type": "Integer",
				"defaultValue": 1
			},
			"api_breweries_hasData": {
				"type": "Boolean",
				"defaultValue": true
			},
			"api_breweries_pagesRead": {
				"type": "Integer",
				"defaultValue": 0
			},
			"api_breweries_nextPage": {
				"type": "Integer",
				"defaultValue": 0
			}
		},
		"annotations": [],
		"lastPublishTime": "2026-04-23T18:06:01Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}