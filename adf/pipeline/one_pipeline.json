{
	"name": "one_pipeline",
	"properties": {
		"activities": [
			{
				"name": "breweries2",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "00:10:00",
					"retry": 3,
					"retryIntervalInSeconds": 60,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "HttpReadSettings",
							"maxConcurrentConnections": 1,
							"requestMethod": "GET",
							"requestTimeout": "00:00:02"
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobFSWriteSettings",
							"maxConcurrentConnections": 1,
							"copyBehavior": "PreserveHierarchy",
							"blockSizeInMB": 4
						},
						"formatSettings": {
							"type": "JsonWriteSettings"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "breweries_json",
						"type": "DatasetReference"
					}
				],
				"outputs": [
					{
						"referenceName": "sink_json_adls2",
						"type": "DatasetReference",
						"parameters": {
							"p_container": "one",
							"p_folder": {
								"value": "@concat(\n    'bronze/api/openbrewery/',\n    'year=', formatDateTime(convertTimeZone(utcNow(),'UTC','E. South America Standard Time'), 'yyyy'),\n    '/month=', formatDateTime(convertTimeZone(utcNow(),'UTC','E. South America Standard Time'), 'MM'),\n    '/day=', formatDateTime(convertTimeZone(utcNow(),'UTC','E. South America Standard Time'), 'dd')\n)",
								"type": "Expression"
							},
							"p_file": {
								"value": "@concat(\n    'breweries_',\n    formatDateTime(\n        convertTimeZone(utcNow(),'UTC','E. South America Standard Time'),\n        'HHmmss'\n    ),\n    '_',\n    pipeline().RunId,\n    '.json'\n)",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"annotations": [],
		"lastPublishTime": "2026-04-23T18:06:01Z"
	},
	"type": "Microsoft.DataFactory/factories/pipelines"
}